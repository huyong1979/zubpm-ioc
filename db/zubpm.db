### FIR Filter Selection for Pilot Tone Separation #####
#
#  0 = 4 tap (low separation), 1 = 100 tap (high separation)

record(bo, "$(P){BPM:$(NO)}FILT:DDC-LP-Sel") {
    field(DESC, "Event Source Select")
    field(DTYP, "PSC Single U32")
    field(OUT , "@psc$(NO) 1 68")
    field(ZNAM,"4TAP")
    field(ONAM,"100TAP")
    field(VAL,"0")
    field(PINI,"YES")
    info(autosaveFields, "VAL")
    field(FLNK, "$(P){BPM:$(NO)}GoRegSingleWrite")
}

### PVs for AFE Voltage and Current Measurement ####

record(ai, "$(P){BPM:$(NO)}Pwr:afe-vin-I") {
    field(DESC, "AFE Vin")
    field(DTYP, "PSC Reg F32")
    field(INP , "@psc$(NO) 32 132")
    field(LINR,"LINEAR")
    field(PREC,"3")
    field(SCAN,"I/O Intr")
    field(HIHI,"5.3")
    field(LOLO,"4.7")
    field(HIGH,"5.2")
    field(LOW,"4.8")
    field(HHSV,"MAJOR")
    field(HSV,"MINOR")
    field(LLSV,"INVALID")
    field(LSV,"MINOR")
}

record(ai, "$(P){BPM:$(NO)}Pwr:afe-iin-I") {
    field(DESC, "AFE Iin")
    field(DTYP, "PSC Reg F32")
    field(INP , "@psc$(NO) 32 136")
    field(LINR,"LINEAR")
    field(PREC,"3")
    field(SCAN,"I/O Intr")
    field(HIHI,"3")
    field(LOLO,"1.8")
    field(HIGH,"2.5")
    field(LOW,"2")
    field(HHSV,"MAJOR")
    field(HSV,"MINOR")
    field(LLSV,"INVALID")
    field(LSV,"MINOR")
}



