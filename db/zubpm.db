    field(SCAN,"I/O Intr")
    field(ZNAM,"Rdy")
    field(ONAM,"Busy")
    #field(ZSV,"NO_ALARM")
    #field(OSV,"MAJOR")
    field(FLNK,"$(P){BPM:$(NO)}TBTstat-Sub")
}

